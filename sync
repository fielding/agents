#!/usr/bin/env bash
set -euo pipefail

AGENTS_SKILLS="$HOME/.agents/skills"

# All agents use a directory-level symlink (skills/ -> ~/.agents/skills/).
DIR_SYMLINK_TARGETS=(
  "$HOME/.claude/skills|../.agents/skills"
  "$HOME/.cursor/skills|../.agents/skills"
  "$HOME/.copilot/skills|../.agents/skills"
  "$HOME/.codex/skills|../.agents/skills"
  "$HOME/.gemini/skills|../.agents/skills"
  "$HOME/.pi/agent/skills|../../.agents/skills"
)

dry_run=false
verbose=false

for arg in "$@"; do
  case "$arg" in
    --dry-run|-n) dry_run=true ;;
    --verbose|-v) verbose=true ;;
    --help|-h)
      echo "Usage: sync [--dry-run] [--verbose]"
      echo ""
      echo "Ensures all agent skill directories point to ~/.agents/skills/."
      echo "All agents get a directory-level symlink to ~/.agents/skills/."
      exit 0
      ;;
  esac
done

log() { $verbose && echo "  $1" || true; }

created=0
skipped=0
warned=0

# --- Directory-level symlinks ---
for entry in "${DIR_SYMLINK_TARGETS[@]}"; do
  target="${entry%%|*}"
  expected="${entry##*|}"

  if [ -L "$target" ]; then
    existing=$(readlink "$target")
    if [ "$existing" = "$expected" ]; then
      log "ok: $target -> $existing"
      skipped=$((skipped + 1))
    else
      echo "warn: $target -> $existing (expected $expected)"
      warned=$((warned + 1))
    fi
  elif [ -d "$target" ]; then
    echo "warn: $target is a real directory, not a symlink"
    warned=$((warned + 1))
  else
    if $dry_run; then
      echo "would create: $target -> $expected"
    else
      mkdir -p "$(dirname "$target")"
      ln -s "$expected" "$target"
      log "created: $target -> $expected"
    fi
    created=$((created + 1))
  fi
done

echo "sync: $created created, $skipped ok, $warned warnings"
